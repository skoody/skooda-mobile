{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "skooda-mobile",
  "version": "0.8.5",
  "identifier": "com.skooda.mobile",
  "build": {
    "frontendDist": "../src",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "skooda-mobile",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "versionCode": 82
    }
  }
}
